{
    "include": [
        "src/**/*.ts",
        "src/**/*.vue"
    ],
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "preserve",
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],
        "types": ["vite/client"],
        "rootDir": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "sourceMap": true,
        "strict": false,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "esModuleInterop": true
    }
}